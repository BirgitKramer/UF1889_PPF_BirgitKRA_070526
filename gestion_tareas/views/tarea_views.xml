<!-- Definición de la vista tipo lista -->
    <record id="view_gestion_tarea_list" model="ir.ui.view">
        <field name="name">gestion.tarea.list</field>
        <field name="model">gestion.tarea</field>
        <field name="arch" type="xml">
            <list string="Tareas">
                <field name="nombre"/>
                <field name="cliente_id"/>
                <field name="fecha"/>
                <field name="estado"/>
            </list>
        </field>
    </record>
    
    <!-- Vista formulario -->
    <record id="view_gestion_tarea_form" model="ir.ui.view">
        <field name="name">gestion.tarea.form</field>
        <field name="model">gestion.tarea</field>
        <field name="arch" type="xml">
            <form string="Tarea">
                <header>
                    <button name="action_marcar_finalizada"
                            type="object"
                            string="Marcar como finalizada"
                            class="btn-primary"
                            invisible="estado == 'finalizada'"/>
                </header>

                <sheet>
                    <group>
                        <field name="nombre"/>
                        <field name="cliente_id"/>
                        <field name="fecha"/>
                        <field name="estado"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista busqueda -->
    <record id="view_gestion_tarea_search" model="ir.ui.view">
        <field name="name">gestion.tarea.search</field>
        <field name="model">gestion.tarea</field>
        <field name="arch" type="xml">
            <search string="Buscar Tareas">
                <field name="nombre"/>
                <field name="cliente_id"/>
                <filter name="filtro_pendientes"
                        string="Tareas pendientes"
                        domain="[('estado', '=', 'pendiente')]"/>
                <separator/>
                <filter name="group_cliente"
                            string="Cliente"
                            context="{'group_by': 'cliente_id'}"/>                   
                <filter name="group_estado"
                        string="Estado"
                        context="{'group_by': 'estado'}"/>
            </search>
        </field>
    </record>

    <!-- Acción de ventana -->
    <!-- Permite abrir el modelo desde el menú -->
    <record id="action_gestion_tarea" model="ir.actions.act_window">
        <field name="name">Tareas</field>
        <field name="res_model">gestion.tarea</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="gestion_tareas.view_gestion_tarea_search"/>
    </record>

    <!-- Menú principal del módulo -->
    <menuitem id="menu_gestion_tareas_root"
              name="Gestión de Tareas"
              sequence="10"/>
    
    <menuitem id="menu_gestion_tareas"
              name="Tareas"
              parent="menu_gestion_tareas_root"
              action="action_gestion_tarea"
              sequence="10"/>
              